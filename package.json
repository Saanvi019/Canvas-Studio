{
  "name": "canvasStudio",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@huggingface/inference": "^4.13.21",
    "express-rate-limit": "^8.5.2",
    "groq-sdk": "^1.3.0",
    "lodash": "^4.18.1",
    "multer": "^2.2.0",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  }
}
